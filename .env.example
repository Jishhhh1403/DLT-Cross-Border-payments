# Tokenized Deposit POC — Environment Configuration
# Copy this file to .env and fill in your secrets.
# NEVER commit .env to version control.

# Besu node connection
BESU_RPC_URL=http://besu:8545
CHAIN_ID=1337

# Bank operator private key — DEV ONLY, use HSM in production
BANK_PRIVATE_KEY=0x1111111111111111111111111111111111111111111111111111111111111111

# Alice's private key (for signing transfers)
ALICE_PRIVATE_KEY=0x2222222222222222222222222222222222222222222222222222222222222222

# On-chain addresses for Alice and Bob
ALICE_ONCHAIN_ADDRESS=0x1563915e194D8CfBA1943570603F7606A3115508
BOB_ONCHAIN_ADDRESS=0x5CbDd86a2FA8Dc4bDdd8a8f69dBa48572EeC07FB

# Contract deployment
CONTRACT_ADDRESS_FILE=/app/deployed/contract_address.txt
CONTRACTS_DIR=/app/contracts
